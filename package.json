{
  "name": "nagriksetu",
  "version": "0.1.0",
  "private": true,
  "description": "Citizen-first search and navigation layer for public information in India.",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "ingest:demo": "node --import tsx scripts/ingest-demo.ts",
    "validate:data": "node --import tsx scripts/ingest-demo.ts --check",
    "audit:local": "pnpm run validate:data && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.9",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
